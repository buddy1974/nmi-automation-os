datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// ── Branches ──────────────────────────────────────────────────────────────────

model Branch {
  id     Int     @id @default(autoincrement())
  name   String
  city   String
  region String

  orders Order[]
  stock  Stock[]

  @@map("branches")
}

// ── Products (books) ──────────────────────────────────────────────────────────

model Product {
  id            Int         @id @default(autoincrement())
  code          String      @unique
  title         String
  level         String      @default("Primary")
  class         String      @default("")
  subject       String      @default("")
  author        String      @default("Unknown")
  royaltyType   String      @default("percent") @map("royalty_type")
  royaltyValue  Decimal     @default(10)         @map("royalty_value")
  price         Decimal     @default(0)
  stock         Int         @default(0)

  stockHistory StockHistory[]

  @@map("products")
}

// ── Customers ─────────────────────────────────────────────────────────────────

model Customer {
  id          Int     @id @default(autoincrement())
  name        String
  phone       String  @default("")
  address     String  @default("")
  type        String  @default("individual")
  region      String  @default("")
  creditLimit Decimal @default(0) @map("credit_limit")
  status      String  @default("active")

  orders Order[]

  @@map("customers")
}

// ── Orders ────────────────────────────────────────────────────────────────────

model Order {
  id           Int         @id @default(autoincrement())
  number       String      @unique
  customerId   Int?        @map("customer_id")
  customerName String      @default("") @map("customer_name")
  branchId     Int?        @map("branch_id")
  date         DateTime    @default(now()) @db.Date
  total        Decimal     @default(0)
  status       String      @default("pending")
  companyId    String?     @map("company_id")

  customer  Customer?   @relation(fields: [customerId], references: [id])
  branch    Branch?     @relation(fields: [branchId], references: [id])
  items     OrderItem[]
  invoice   Invoice?
  company   Company?    @relation(fields: [companyId], references: [id])

  @@map("orders")
}

// ── Order items ───────────────────────────────────────────────────────────────

model OrderItem {
  id          Int     @id @default(autoincrement())
  orderId     Int     @map("order_id")
  productCode String  @map("product_code")
  title       String  @default("")
  qty         Int     @default(1)
  price       Decimal @default(0)
  lineTotal   Decimal @default(0) @map("line_total")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_items")
}

// ── Invoices ──────────────────────────────────────────────────────────────────

model Invoice {
  id           Int      @id @default(autoincrement())
  number       String   @unique @default("")
  orderId      Int      @unique @map("order_id")
  customerName String   @default("") @map("customer_name")
  amount       Decimal  @default(0)
  dueDate      DateTime @map("due_date") @db.Date
  status       String   @default("issued")
  paid         Decimal  @default(0)
  createdAt    DateTime @default(now()) @map("created_at")
  companyId    String?  @map("company_id")

  order   Order    @relation(fields: [orderId], references: [id])
  company Company? @relation(fields: [companyId], references: [id])

  @@map("invoices")
}

// ── Authors ───────────────────────────────────────────────────────────────────

model Author {
  id    Int    @id @default(autoincrement())
  name  String
  phone String @default("")
  email String @default("")

  @@map("authors")
}

// ── Royalties ─────────────────────────────────────────────────────────────────

model Royalty {
  id     Int      @id @default(autoincrement())
  author String
  book   String   @default("")
  amount Decimal  @default(0)
  date   DateTime @default(now()) @db.Date
  status String   @default("unpaid")

  @@map("royalties")
}

// ── Manuscripts ───────────────────────────────────────────────────────────────

model Manuscript {
  id             Int      @id @default(autoincrement())
  title          String
  author         String   @default("")
  subject        String   @default("")
  level          String   @default("Primary")
  class          String   @default("")
  status         String   @default("submitted")
  notes          String   @default("")
  date           DateTime @default(now()) @db.Date
  version        Int      @default(1)
  editor         String   @default("")
  editorNotes    String   @default("") @map("editor_notes")
  approved       Boolean  @default(false)
  readyForPrint  Boolean  @default(false) @map("ready_for_print")
  suggestedCode  String   @default("")   @map("suggested_code")
  aiReport       String   @default("")   @map("ai_report")
  aiEditReport   String   @default("")   @map("ai_edit_report")

  history ManuscriptHistory[]

  @@map("manuscripts")
}

// ── Manuscript history ────────────────────────────────────────────────────────

model ManuscriptHistory {
  id           Int      @id @default(autoincrement())
  manuscriptId Int      @map("manuscript_id")
  version      Int
  date         DateTime @default(now()) @db.Date
  editor       String   @default("")
  notes        String   @default("")

  manuscript Manuscript @relation(fields: [manuscriptId], references: [id], onDelete: Cascade)

  @@map("manuscript_history")
}

// ── Workers (HR) ──────────────────────────────────────────────────────────────

model Worker {
  id           Int      @id @default(autoincrement())
  name         String
  nationalId   String   @default("") @map("national_id")
  cnpsNumber   String   @default("") @map("cnps_number")
  phone        String   @default("")
  email        String   @default("")
  role         String   @default("")
  department   String   @default("")
  contractType String   @default("CDI") @map("contract_type")
  startDate    DateTime? @map("start_date") @db.Date
  endDate      DateTime? @map("end_date")   @db.Date
  salaryBase   Decimal  @default(0) @map("salary_base")
  status       String   @default("active")
  companyId    String?  @map("company_id")

  company     Company?           @relation(fields: [companyId], references: [id])
  performance PerformanceRecord[]

  @@map("workers")
}

// ── Printing jobs ─────────────────────────────────────────────────────────────

model PrintingJob {
  id       Int      @id @default(autoincrement())
  book     String
  quantity Int      @default(0)
  cost     Decimal  @default(0)
  printer  String   @default("")
  date     DateTime @default(now()) @db.Date
  status   String   @default("planned")

  @@map("printing_jobs")
}

// ── Stock (per branch) ────────────────────────────────────────────────────────

model Stock {
  id         Int    @id @default(autoincrement())
  titleCode  String @map("title_code")
  branchId   Int    @map("branch_id")
  qty        Int    @default(0)

  branch Branch @relation(fields: [branchId], references: [id])

  @@unique([titleCode, branchId])
  @@map("stock")
}

// ── Cost records (accounting) ─────────────────────────────────────────────────

model CostRecord {
  id     Int      @id @default(autoincrement())
  book   String   @default("")
  type   String   @default("other")
  amount Decimal  @default(0)
  date   DateTime @default(now()) @db.Date
  notes  String   @default("")

  @@map("cost_records")
}

// ── Payments (HR payroll) ─────────────────────────────────────────────────────

model Payment {
  id     Int      @id @default(autoincrement())
  worker String
  type   String   @default("salary")
  amount Decimal  @default(0)
  date   DateTime @default(now()) @db.Date
  notes  String   @default("")

  @@map("payments")
}

// ── Stock history ─────────────────────────────────────────────────────────────

model StockHistory {
  id          Int      @id @default(autoincrement())
  productId   Int      @map("product_id")
  change      Int
  reason      String   @default("manual")
  note        String   @default("")
  createdAt   DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("stock_history")
}

// ── Automation jobs ───────────────────────────────────────────────────────────

model AutomationJob {
  id        Int      @id @default(autoincrement())
  type      String
  payload   Json
  status    String   @default("pending")
  result    Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@map("automation_jobs")
}

// ── Companies ─────────────────────────────────────────────────────────────────

model Company {
  id     String  @id @default(cuid())
  name   String
  city   String  @default("")
  active Boolean @default(true)

  users    User[]
  workers  Worker[]
  orders   Order[]
  invoices Invoice[]

  @@map("companies")
}

// ── Users ─────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      String   @default("viewer")
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  companyId String?  @map("company_id")

  company Company? @relation(fields: [companyId], references: [id])

  @@map("users")
}

// ── Distributors ──────────────────────────────────────────────────────────────

model Distributor {
  id        String   @id @default(cuid())
  name      String
  region    String
  city      String
  phone     String?
  email     String?
  address   String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  companyId String?  @map("company_id")

  @@map("distributors")
}

// ── Performance records (PeopleOS AI) ────────────────────────────────────────

model PerformanceRecord {
  id             Int      @id @default(autoincrement())
  workerId       Int      @map("worker_id")
  period         String
  attendance     Float    @default(0)
  productivity   Float    @default(0)
  quality        Float    @default(0)
  teamwork       Float    @default(0)
  discipline     Float    @default(0)
  managerNote    String?  @map("manager_note")
  aiSummary      String?  @map("ai_summary")
  totalScore     Float    @default(0) @map("total_score")
  scorePercent   Float    @default(0) @map("score_percent")
  rating         String?
  bonusScore     Float    @default(0) @map("bonus_score")
  recommendation String?
  baseSalary     Float?   @map("base_salary")
  bonusPercent   Float?   @map("bonus_percent")
  bonusAmount    Float?   @map("bonus_amount")
  suggestedSalary Float?  @map("suggested_salary")
  salaryIncrease Float?   @map("salary_increase")
  aiBonusSummary String?  @map("ai_bonus_summary")
  createdAt      DateTime @default(now()) @map("created_at")

  worker Worker @relation(fields: [workerId], references: [id])

  @@map("performance_records")
}

// ── Audit log ──────────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  action    String
  entity    String
  entityId  String?  @map("entity_id")
  details   String?
  ip        String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}
